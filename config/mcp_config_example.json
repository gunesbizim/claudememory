{
  "_comment": "Add the 'mcpServers' block to your existing ~/.claude/claude_desktop_config.json",
  "mcpServers": {
    "claudememory": {
      "command": "python",
      "args": ["/ABSOLUTE/PATH/TO/YOUR/REPO/ai/claude_memory_mcp_server.py"],
      "env": {
        "CLAUDE_MEMORY_REPO_PATH": "/ABSOLUTE/PATH/TO/YOUR/REPO",
        "CLAUDE_MEMORY_USER_ID": "claude_memory_system",
        "MEM0_API_KEY": "YOUR_MEM0_API_KEY_OR_LEAVE_EMPTY_FOR_LOCAL_CHROMA",
        "CLAUDE_MEMORY_CHROMA_DIR": "/Users/YOU/.cache/claude_memory/chroma"
      }
    }
  }
}
